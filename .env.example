APP_ENV=development
APP_NAME=Bazaar Mind Games
DATA_ROOT=./data
DATABASE_URL=sqlite:///./data/processed/bazaar_mind_games.db
DEFAULT_SYMBOL=NIFTY_FUT
TIMEZONE=Asia/Kolkata
TRUEDATA_BASE_URL=https://history.truedata.in
TRUEDATA_BEARER_TOKEN=
TRUEDATA_TIMEOUT_SECONDS=10
TRUEDATA_MAX_RETRIES=2
TRUEDATA_BIDASK=1
TRUEDATA_COMP=false
TRUEDATA_LIVE_USERNAME=
TRUEDATA_LIVE_PASSWORD=
TRUEDATA_LIVE_URL=push.truedata.in
TRUEDATA_LIVE_PORT=9084
TRUEDATA_LIVE_FULL_FEED=true
TRUEDATA_LIVE_DRY_RUN=false
TRUEDATA_LIVE_BACKFILL_INTERVAL=1min
TRUEDATA_LIVE_BACKFILL_BARS=200
